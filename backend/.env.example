# ── Pacifica ──────────────────────────────────────────────────────────────────
PACIFICA_REST_URL=https://test-api.pacifica.fi/api/v1
PACIFICA_WS_URL=wss://test-ws.pacifica.fi/ws
PACIFICA_API_CONFIG_KEY=           # PF-API-KEY header value (rate-limit key)

# ── Agent Key (Ed25519 keypair for signing orders) ─────────────────────────────
# Generated once at bootstrap; private key is encrypted in Redis at runtime.
# Store the raw base58 private key here ONLY during initial bootstrap.
# After first run, delete this value and rely on Redis.
AGENT_KEY_PRIVATE_KEY_B58=         # base58-encoded 64-byte Ed25519 private key
AGENT_KEY_PUBLIC_KEY=              # base58-encoded 32-byte Ed25519 public key

# ── Fernet encryption master secret ──────────────────────────────────────────
# Used to derive the Fernet key for encrypting the Agent Key in Redis.
# Must be a 32-byte URL-safe base64 value. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_MASTER_KEY=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Elfa AI ───────────────────────────────────────────────────────────────────
ELFA_API_KEY=
ELFA_BASE_URL=https://api.elfa.ai/v2

# ── Fuul ─────────────────────────────────────────────────────────────────────
FUUL_API_KEY=                      # send:tracking_event key — used by frontend (safe to expose)
FUUL_TRIGGER_KEY=                  # send:trigger_event key — backend only, NEVER put in frontend

# ── Aegis constants ──────────────────────────────────────────────────────────
BUILDER_CODE=AEGIS
VAULT_WALLET_ADDRESS=              # Pacifica sub-account address for the vault
VAULT_PREMIUM_BPS=10               # 0.10% of position notional = 10 bps

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173
