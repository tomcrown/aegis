# ── Privy ─────────────────────────────────────────────────────────────────────
VITE_PRIVY_APP_ID=

# ── Fuul ─────────────────────────────────────────────────────────────────────
VITE_FUUL_API_KEY=                 # send:tracking_event key (safe for client)

# ── Backend ───────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws

# ── Feature flags ─────────────────────────────────────────────────────────────
# DEV_MODE_ENABLED controls whether the Simulate toggle is visible in UI.
# This must NEVER affect backend behaviour.
VITE_DEV_MODE_ENABLED=true
